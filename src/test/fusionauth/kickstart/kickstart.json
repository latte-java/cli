{
  "licenseId": "#{ENV.FUSIONAUTH_APP_LICENSE_KEY}",
  "variables": {
    "apiKey": "33052c8a-c283-4e96-9d2a-eb1215c69f8f-not-for-prod",
    "asymmetricKeyId": "#{UUID()}",
    "cliApplicationId": "cc5f3c9e-b28e-4632-bafe-823363669820",
    "defaultTenantId": "d7d09513-a3f5-401c-9685-34ab6c552453",
    "adminEmail": "admin@lattejava.org",
    "adminPassword": "password",
    "adminUserId": "#{UUID()}",
    "ordinaryEmail": "test@lattejava.org",
    "ordinaryPassword": "password",
    "ordinaryUserId": "#{UUID()}",
    "accessTokenPopulateLambdaId": "9bde7abd-5557-41cc-9a40-1048cac3f64e"
  },
  "apiKeys": [
    {
      "key": "#{apiKey}",
      "description": "Unrestricted API key"
    }
  ],
  "requests": [
    {
      "method": "POST",
      "url": "/api/key/generate/#{asymmetricKeyId}",
      "tenantId": "#{defaultTenantId}",
      "body": {
        "key": {
          "algorithm": "RS256",
          "name": "For Latte App",
          "length": 2048
        }
      }
    },
    {
      "method": "PATCH",
      "url": "/api/tenant/#{defaultTenantId}",
      "body": {
        "tenant": {
          "issuer": "http://localhost:9011"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/lambda/#{accessTokenPopulateLambdaId}",
      "body": {
        "lambda": {
          "name": "[Latte] Access token populate",
          "type": "JWTPopulate",
          "engineType": "GraalJS",
          "body": "function populate(jwt, user, registration) {\n  jwt.preferred_username = user.username;\n  jwt.email = user.email;\n}"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/application/#{cliApplicationId}",
      "tenantId": "#{defaultTenantId}",
      "body": {
        "application": {
          "name": "Latte CLI",
          "oauthConfiguration": {
            "authorizedRedirectURLs": [
              "http://localhost:8888/callback"
            ],
            "clientAuthenticationPolicy": "NotRequired",
            "proofKeyForCodeExchangePolicy": "Required",
            "consentMode": "NeverPrompt",
            "enabledGrants": [
              "authorization_code",
              "refresh_token"
            ],
            "generateRefreshTokens": true,
            "requireRegistration": true
          },
          "jwtConfiguration": {
            "enabled": true,
            "accessTokenKeyId": "#{asymmetricKeyId}",
            "idTokenKeyId": "#{asymmetricKeyId}"
          },
          "lambdaConfiguration": {
            "accessTokenPopulateId": "#{accessTokenPopulateLambdaId}"
          }
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{adminUserId}",
      "body": {
        "registration": {
          "applicationId": "#{FUSIONAUTH_APPLICATION_ID}",
          "roles": [
            "admin"
          ]
        },
        "skipRegistrationVerification": true,
        "user": {
          "email": "#{adminEmail}",
          "username": "AdminUser",
          "password": "#{adminPassword}"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{ordinaryUserId}",
      "body": {
        "registration": {
          "applicationId": "#{cliApplicationId}"
        },
        "skipRegistrationVerification": true,
        "user": {
          "email": "#{ordinaryEmail}",
          "username": "OrdinaryUser",
          "password": "#{ordinaryPassword}"
        }
      }
    },
    {
      "method": "POST",
      "url": "/api/user/registration/#{adminUserId}",
      "body": {
        "registration": {
          "applicationId": "#{cliApplicationId}"
        }
      }
    }
  ]
}
