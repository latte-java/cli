project(group: "org.lattejava.plugin", name: "java", version: "0.4.1", licenses: ["MIT"]) {
  workflow {
    standard()
  }
  publishWorkflow {
    latte()
  }

  dependencies {
    group(name: "provided") {
      dependency(id: "org.lattejava:cli:0.4.0")
    }
    group(name: "compile") {
      dependency(id: "com.googlecode.jarjar:jarjar:1.3")
      dependency(id: "org.lattejava.plugin:dependency:0.4.0")
      dependency(id: "org.lattejava.plugin:file:0.4.0")
    }
    group(name: "test-compile", export: false) {
      dependency(id: "org.testng:testng:7.12.0")
    }
  }

  publications {
    standard()
  }
}

// Plugins
dependency = loadPlugin(id: "org.lattejava.plugin:dependency:0.4.0")
groovy = loadPlugin(id: "org.lattejava.plugin:groovy:0.4.0")
groovyTestNG = loadPlugin(id: "org.lattejava.plugin:groovy-testng:0.4.0")
idea = loadPlugin(id: "org.lattejava.plugin:idea:0.4.0")
release = loadPlugin(id: "org.lattejava.plugin:release-git:0.4.0")

// Plugin settings
groovy.settings.groovyVersion = "5.0"
groovy.settings.javaVersion = "25"
groovy.settings.jarManifest["Latte-Plugin-Class"] = "org.lattejava.plugin.java.JavaPlugin"
groovyTestNG.settings.groovyVersion = "5.0"
groovyTestNG.settings.javaVersion = "25"
release.settings.tag = "${project.name}-${project.version}"

target(name: "clean", description: "Cleans the project") {
  groovy.clean()
}

target(name: "build", description: "Compiles and JARs the project") {
  groovy.compile()
  groovy.jar()
}

target(name: "test", description: "Runs the project's tests", dependsOn: ["build"]) {
  groovyTestNG.test()
}

target(name: "int", description: "Releases a local integration build of the project", dependsOn: ["test"]) {
  dependency.integrate()
}

target(name: "release", description: "Releases a full version of the project", dependsOn: ["clean", "test"]) {
  release.release()
}

target(name: "idea", description: "Updates the IntelliJ IDEA module file") {
  idea.iml()
}
